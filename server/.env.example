MONGODB_URL=mongodb://localhost:27017/name
JWT_SECRET='secretkey'

FRONTEND_URL=http://localhost:5173


# TraceHub API Keys (Update with your actual keys)
PORT=3000
REQUESTY_API_KEY=your_requesty_api_key_here
DUALITY_API_KEY=your_duality_api_key_here
ALGORAND_ADMIN_MNEMONIC=enter your 25-word testnet mnemonic here
DEMO_FALLBACK_TXID=DEMO_TXID_PLACEHOLDER


# ── AI Routing (Requesty) ─────────────────────────────────────────────────────
# Sign up at https://requesty.ai and grab your key
REQUESTY_API_KEY=your_requesty_api_key_here

# ── Decentralised Storage (Pinata / IPFS) ─────────────────────────────────────
# 1. Sign up FREE at https://app.pinata.cloud
# 2. Go to API Keys → New Key → check "pinFileToIPFS" → Generate
# 3. Copy the JWT (not the API key) and paste below
# If left blank the app still works — files get a mock IPFS URL for the demo.
PINATA_JWT=your_pinata_jwt_here

# ── Blockchain Notary (Algorand Testnet) ──────────────────────────────────────
# WARNING: testnet wallet only — never use mainnet funds here!
# Get a 25-word mnemonic from Pera Wallet (testnet) or run:
#   node -e "const a=require('algosdk');const k=a.generateAccount();console.log(a.secretKeyToMnemonic(k.sk),k.addr)"
# Fund the address at https://testnet.algoexplorer.io/dispenser
ALGORAND_ADMIN_MNEMONIC=word1 word2 word3 ... word25

# Algorand node (free public testnet node — no account needed)
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=
