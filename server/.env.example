MONGODB_URL=mongodb://localhost:27017/name
JWT_SECRET='secretkey'

FRONTEND_URL=http://localhost:5173
PORT=3000

# ── Demo Mode & File Storage ─────────────────────────────────────────────────
# Set DEMO_MODE=true to enable demo mode with Cloudinary file storage
DEMO_MODE=false

# Cloudinary credentials (required when DEMO_MODE=true)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

PINATA_JWT=your_pinata_jwt_here

# ── Blockchain Notary (Algorand Testnet) ──────────────────────────────────────
ALGORAND_ADMIN_MNEMONIC=word1 word2 word3 ... word25

# Algorand node (free public testnet node — no account needed)
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=xxxxxxxxxxxxxxxxxxxx
